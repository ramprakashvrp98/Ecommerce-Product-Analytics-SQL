-- TRANSACTIONS TABLE
create table transactions(
transaction_id int,
timestamp datetime,
customer_id int,
product_id int,
quantity int,
discount_applied decimal(5,2),
gross_revenue decimal (5,2),
campaign_id int,
refund_flag boolean);

